@model InstructorLessonsVM

<div class="d-flex justify-content-between align-items-center mb-3">

    <h4 class="mb-0">Lessons</h4>

    <button class="btn btn-primary"
            data-toggle="modal"
            data-target="#createLessonModal">

        <i class="fas fa-plus mr-1"></i>

        Add Lesson

    </button>

</div>

@if (!Model.Lessons.Any())
{
    <div class="alert alert-info">

        No lessons found.

    </div>
}
else
{
    <table class="table table-bordered table-hover">

        <thead>

            <tr>

                <th>Title</th>

                <th>Video</th>

                <th>PDF</th>

                <th width="180">Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var lesson in Model.Lessons)
            {
                <tr>

                    <td>@lesson.Title</td>

                    <td>

                        @if (!string.IsNullOrWhiteSpace(lesson.VideoUrl))
                        {
                            <span class="badge badge-success">

                                    <a href="@lesson.VideoUrl"
                                       target="_blank"
                                       class="text-white">
                                        Video
                                    </a>

                            </span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">

                                -

                            </span>
                        }

                    </td>

                    <td>

                        @if (!string.IsNullOrWhiteSpace(lesson.PdfPath))
                        {
                            <a href="@lesson.PdfPath"
                               target="_blank"
                               class="btn btn-sm btn-outline-danger">

                                PDF

                            </a>
                        }
                        else
                        {
                            <span class="badge badge-secondary">

                                -

                            </span>
                        }

                    </td>

                    <td>

                        <button class="btn btn-warning btn-sm edit-lesson-btn"
                                data-toggle="modal"
                                data-target="#editLessonModal"
                                data-id="@lesson.LessonId"
                                data-courseid="@Model.CourseId"
                                data-title="@lesson.Title"
                                data-content="@lesson.Content"
                                data-video="@lesson.VideoUrl"
                                data-pdf="@lesson.PdfPath">

                            <i class="fas fa-edit"></i>

                        </button>

                        <form asp-action="DeleteLesson"
                              method="post"
                              class="d-inline delete-lesson-form">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="lessonId"
                                   value="@lesson.LessonId" />

                            <input type="hidden"
                                   name="courseId"
                                   value="@Model.CourseId" />

                            <button type="submit"
                                    class="btn btn-danger btn-sm">

                                <i class="fas fa-trash"></i>

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>
}

@await Html.PartialAsync(
"_CreateLessonModal",
new CreateLessonVM
{
    CourseId = Model.CourseId
})  
@await Html.PartialAsync("_EditLessonModal", new InstructorEditLessonVM())

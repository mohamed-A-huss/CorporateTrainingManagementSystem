@model CorporateTrainingManagementSystem.ViewModels.Identity.ResetPasswordVM
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory Factory
@{
    ViewData["Title"] = "Reset Password";
    ViewData["BodyClass"] = "login-page";
    var Localizer = Factory.Create(
        "SharedResource",
        "CorporateTrainingManagementSystem");
}

<div class="login-box">

    <div class="login-logo">

        <a asp-area=""
           asp-controller="Home"
           asp-action="Index">

            <b>Corporate</b>Training

        </a>

    </div>

    <div class="card">

        <div class="card-body login-card-body">

            <p class="login-box-msg">

                @Localizer["Reset your password below."]

            </p>

            <form asp-action="ResetPassword"
                  method="post">

                @Html.AntiForgeryToken()

                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <!-- New Password -->

                <div class="input-group mb-3">

                    <input asp-for="NewPassword"
                           class="form-control"
                           id="NewPassword"
                           placeholder="New Password" />

                    <div class="input-group-append">

                        <button type="button"
                                class="btn btn-outline-secondary border-left-0"
                                id="toggleNewPassword">

                            <i class="fas fa-eye"></i>

                        </button>

                    </div>

                </div>

                <span asp-validation-for="NewPassword"
                      class="text-danger">
                </span>

                <!-- Confirm Password -->

                <div class="input-group mb-3">

                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           id="ConfirmPassword"
                           placeholder="Confirm Password" />

                    <div class="input-group-append">

                        <button type="button"
                                class="btn btn-outline-secondary border-left-0"
                                id="toggleConfirmPassword">

                            <i class="fas fa-eye"></i>

                        </button>

                    </div>

                </div>

                <span asp-validation-for="ConfirmPassword"
                      class="text-danger">
                </span>

                <button type="submit"
                        class="btn btn-success btn-block">

                    @Localizer["Reset Password"]

                </button>

            </form>

            <hr />

            <p class="mb-0 text-center">

                <a asp-action="Login">

                    @Localizer["Back to Login"]

                </a>

            </p>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        function togglePassword(inputId, buttonId)
        {
            const input = document.getElementById(inputId);
            const button = document.getElementById(buttonId);

            button.addEventListener("click", function ()
            {
                if (input.type === "password")
                {
                    input.type = "text";
                    this.innerHTML =
                        '<i class="fas fa-eye-slash"></i>';
                }
                else
                {
                    input.type = "password";
                    this.innerHTML =
                        '<i class="fas fa-eye"></i>';
                }
            });
        }

        togglePassword("NewPassword", "toggleNewPassword");
        togglePassword("ConfirmPassword", "toggleConfirmPassword");

    </script>
}
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory Factory
@{
    ViewData["Title"] = "404";
    var Localizer = Factory.Create(
        "SharedResource",
        "CorporateTrainingManagementSystem");
}

<div class="text-center mt-5">

    <h1 class="display-1 text-danger">

        404

    </h1>

    <h3>

        @Localizer["Page Not Found"]

    </h3>

    <p>
        
        @Localizer["The page you are looking for does not exist."]

    </p>

    <a asp-controller="Home"
       asp-action="Index"
       class="btn btn-primary">

        <i class="fas fa-home mr-2"></i>

        @Localizer["Back to Home"]

    </a>

</div>
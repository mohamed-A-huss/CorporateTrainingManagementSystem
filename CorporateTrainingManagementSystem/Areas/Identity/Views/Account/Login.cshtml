@model LoginVM
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory Factory
@{
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "login-page";
    var Localizer = Factory.Create(
        "SharedResource",
        "CorporateTrainingManagementSystem");
}

<div class="login-box">

    <div class="login-logo">

        <a asp-area=""
           asp-controller="Home"
           asp-action="Index">

            <b>Corporate</b>Training

        </a>

    </div>

    <div class="card shadow">

        <div class="card-body login-card-body">

            <p class="login-box-msg">

                @Localizer["Sign in to continue"]

            </p>

            <form asp-action="Login"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <!-- Email -->

                <div class="input-group mb-3">

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Email" />

                    <div class="input-group-append">

                        <div class="input-group-text">

                            <span class="fas fa-envelope"></span>

                        </div>

                    </div>

                </div>

                <span asp-validation-for="Email"
                      class="text-danger">
                </span>

                <!-- Password -->

                <div class="input-group mb-3">

                    <input asp-for="Password"
                           class="form-control"
                           id="Password"
                           placeholder="Password" />

                    <div class="input-group-append">

                        <button type="button"
                                class="btn btn-outline-secondary border-left-0"
                                id="togglePassword">

                            <i class="fas fa-eye"></i>

                        </button>

                    </div>

                </div>

                <span asp-validation-for="Password"
                      class="text-danger">
                </span>

                <!-- Remember -->

                <div class="row">

                    <div class="col-8">

                        <div class="icheck-primary">

                            <input asp-for="RememberMe" />

                            <label asp-for="RememberMe"></label>

                        </div>

                    </div>

                    <div class="col-4">

                        <button type="submit"
                                class="btn btn-primary btn-block">

                            @Localizer["Login"]

                        </button>

                    </div>

                </div>

            </form>

            <p class="mt-3 mb-1">

                <a asp-action="ForgotPassword">

                    @Localizer["Forgot Password"]?

                </a>

            </p>

            <hr />

            <!-- External Login -->

            <div class="social-auth-links text-center mb-3">

                <p>- @Localizer["OR"] -</p>

                <form asp-action="ExternalLogin"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            name="provider"
                            value="Google"
                            class="btn btn-block btn-danger mb-2">

                        <i class="fab fa-google mr-2"></i>

                        @Localizer["Sign in using Google"]

                    </button>

                </form>

            </div>
            <hr />

            <div class="card card-outline card-info mt-3">

                <div class="card-header">

                    <h5 class="mb-0">

                        <i class="fas fa-user-shield mr-2"></i>

                        Demo Accounts

                    </h5>

                </div>

                <div class="card-body p-3">

                    <div class="mb-3">

                        <span class="badge badge-danger">

                            Super Admin

                        </span>

                        <div class="mt-2">

                            <strong>Email:</strong>

                            superadmin@cts.com

                        </div>

                        <div>

                            <strong>Password:</strong>

                            SuperAdmin@123

                        </div>

                    </div>

                    <hr />

                    <div class="mb-3">

                        <span class="badge badge-success">

                            Instructor

                        </span>

                        <div class="mt-2">

                            <strong>Email:</strong>

                            mohamed.ibrahim@cts.com

                        </div>

                        <div>

                            <strong>Password:</strong>

                            Instructor@123

                        </div>

                    </div>

                    <hr />

                    <div>

                        <span class="badge badge-primary">

                            Trainee

                        </span>

                        <div class="mt-2">

                            <strong>Email:</strong>

                            omar.adel@cts.com

                        </div>

                        <div>

                            <strong>Password:</strong>

                            Student@123

                        </div>

                    </div>

                </div>

            </div>

            <div class="text-center mt-3">

                <a href="https://github.com/mohamed-A-huss/CorporateTrainingManagementSystem"
                   target="_blank"
                   class="btn btn-dark btn-sm">

                    <i class="fab fa-github mr-1"></i>

                    GitHub Repository

                </a>

            </div>

            <p class="mb-0 text-center">

                Don't have an account?

                <a asp-action="Register">

                    @Localizer["Register here"]]

                </a>

            </p>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        const password =
            document.getElementById("Password");

        const toggle =
            document.getElementById("togglePassword");

        toggle.addEventListener("click", function () {

            if (password.type === "password") {

                password.type = "text";

                this.innerHTML =
                    '<i class="fas fa-eye-slash"></i>';

            }
            else {

                password.type = "password";

                this.innerHTML =
                    '<i class="fas fa-eye"></i>';

            }

        });

    </script>
}
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory Factory
@{
    ViewData["Title"] = "Access Denied";
    var Localizer = Factory.Create(
        "SharedResource",
        "CorporateTrainingManagementSystem");
}

<div class="d-flex justify-content-center align-items-center"
     style="min-height:80vh;">

    <div class="text-center">

        <h1 class="display-3 text-danger">

            403

        </h1>

        <h3 class="mb-3">

            @Localizer["Access Denied"]

        </h3>

        <p class="text-muted mb-4">

            @Localizer["You do not have permission to access this page."]

        </p>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-primary">

            <i class="fas fa-home mr-2"></i>

            @Localizer["Back to Home"]

        </a>

    </div>

</div>
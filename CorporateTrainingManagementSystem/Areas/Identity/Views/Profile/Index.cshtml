@model CorporateTrainingManagementSystem.ViewModels.Identity.ProfileVM

@{
    ViewData["Title"] = "My Profile";
}

<div class="content-wrapper">

    <section class="content-header">

        <div class="container-fluid">

            <div class="row mb-2">


                <div class="col-sm-6">

                    <h1>My Profile</h1>

                </div>

            </div>

        </div>

    </section>

    <section class="content">

        <div class="container-fluid">

            <div class="row justify-content-center">

                <div class="col-md-8">

                    <div class="card card-primary card-outline">

                        <div class="card-body box-profile">

                            <div class="text-center">

                                <img class="profile-user-img img-fluid img-circle"
                                     src="@(string.IsNullOrWhiteSpace(Model.ProfilePicture) ? Url.Content("~/AdminLTE/dist/img/default user.jpg")
                                                                                              : Url.Content(Model.ProfilePicture))"
                                     alt="Profile Picture">

                            </div>

                            <h3 class="profile-username text-center">

                                @Model.FullName

                            </h3>

                            <p class="text-muted text-center">

                                @Model.Role

                            </p>

                            <ul class="list-group list-group-unbordered mb-3">

                                <li class="list-group-item">

                                    <b>Email</b>

                                    <span class="float-right">

                                        @Model.Email

                                    </span>

                                </li>

                                <li class="list-group-item">

                                    <b>Phone Number</b>

                                    <span class="float-right">

                                        @Model.PhoneNumber

                                    </span>

                                </li>

                                <li class="list-group-item">

                                    <b>Department</b>

                                    <span class="float-right">

                                        @Model.Department

                                    </span>

                                </li>

                                <li class="list-group-item">

                                    <b>Role</b>

                                    <span class="float-right">

                                        @switch (Model.Role)
                                        {
                                            case "Admin":
                                                <span class="badge badge-danger">
                                                    Admin
                                                </span>
                                                break;

                                            case "Instructor":
                                                <span class="badge badge-primary">
                                                    Instructor
                                                </span>
                                                break;

                                            default:
                                                <span class="badge badge-success">
                                                    Trainee
                                                </span>
                                                break;
                                        }

                                    </span>

                                </li>

                                <li class="list-group-item">

                                    <b>Email Status</b>

                                    <span class="float-right">

                                        @if (Model.EmailConfirmed)
                                        {
                                            <span class="badge badge-success">

                                                <i class="fas fa-check-circle mr-1"></i>

                                                Verified

                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">

                                                <i class="fas fa-clock mr-1"></i>

                                                Pending Verification

                                            </span>
                                        }

                                    </span>

                                </li>

                            </ul>

                            <div class="text-center">

                                <a asp-action="Edit"
                                   class="btn btn-warning mr-2">

                                    <i class="fas fa-user-edit mr-1"></i>

                                    Edit Profile

                                </a>

                                <a asp-action="ChangePassword"
                                   class="btn btn-primary">

                                    <i class="fas fa-key mr-1"></i>

                                    Change Password

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

</div>

@section Scripts
{
    <partial name="_NotificationPartial" />
}
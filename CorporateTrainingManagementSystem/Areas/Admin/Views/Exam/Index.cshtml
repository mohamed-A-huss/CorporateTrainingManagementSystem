@model PaginatedExam

@{
    var courses = ViewBag.Courses as IEnumerable<SelectListItem>;
}

<div class="container">

    <div class="row mb-3 align-items-center my-3">

        <div class="col-md-6">
            <h2 class="display-6">All Exams</h2>
        </div>

        <div class="col-md-6 text-end">

            <a asp-action="Create"
               class="btn btn-success">

                <i class="bi bi-plus-circle"></i>

                Create

            </a>

        </div>

    </div>

    <section class="py-3 filter-bar">

        <div class="container">

            <form method="get">

                <div class="row g-2">

                    <div class="col-md-3">

                        <input asp-for="Filter.Title"
                               class="form-control"
                               placeholder="Exam Title" />

                    </div>

                    <div class="col-md-3">

                        <select asp-for="Filter.CourseId"
                                asp-items="courses"
                                class="form-select">

                            <option value="">All Courses</option>

                        </select>

                    </div>

                    <div class="col-md-2">

                        <input asp-for="Filter.MinPassMark"
                               class="form-control"
                               placeholder="Min Pass Mark" />

                    </div>

                    <div class="col-md-2">

                        <input asp-for="Filter.MaxPassMark"
                               class="form-control"
                               placeholder="Max Pass Mark" />

                    </div>

                    <div class="col-md-2">

                        <button class="btn btn-dark w-100">

                            Filter

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </section>

    <table class="table table-hover mt-4">

        <thead>

            <tr>

                <th>ID</th>

                <th>Title</th>

                <th>Course</th>

                <th>Duration</th>

                <th>Pass Mark</th>

                <th>Total Marks</th>

                <th width="240">Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Exams)
            {
                <tr>

                    <td>@item.ExamId</td>

                    <td>@item.Title</td>

                    <td>@item.CourseTitle</td>

                    <td>@item.DurationMinutes min</td>

                    <td>@item.PassMark</td>

                    <td>@item.TotalMarks</td>

                    <td>

                        <a asp-action="Details"
                           asp-route-id="@item.ExamId"
                           class="btn btn-info">

                            <i class="bi bi-eye"></i>

                            Details

                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@item.ExamId"
                           class="btn btn-warning">

                            <i class="bi bi-pencil-square"></i>

                            Edit

                        </a>

                        <form asp-action="Delete"
                              asp-route-id="@item.ExamId"
                              method="post"
                              class="d-inline delete-form">

                            @Html.AntiForgeryToken()

                            <button type="button"
                                    class="btn btn-danger btn-delete">

                                <i class="bi bi-trash"></i>

                                Delete

                            </button>

                        </form>

                    </td>

                </tr>
            }

        </tbody>

    </table>

    <nav>

        <ul class="pagination justify-content-center">

            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage - 1)"
                       asp-route-Filter.Title="@Model.Filter?.Title"
                       asp-route-Filter.CourseId="@Model.Filter?.CourseId"
                       asp-route-Filter.MinPassMark="@Model.Filter?.MinPassMark"
                       asp-route-Filter.MaxPassMark="@Model.Filter?.MaxPassMark">

                        Previous

                    </a>

                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-Filter.Title="@Model.Filter?.Title"
                       asp-route-Filter.CourseId="@Model.Filter?.CourseId"
                       asp-route-Filter.MinPassMark="@Model.Filter?.MinPassMark"
                       asp-route-Filter.MaxPassMark="@Model.Filter?.MaxPassMark">

                        @i

                    </a>

                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@(Model.CurrentPage + 1)"
                       asp-route-Filter.Title="@Model.Filter?.Title"
                       asp-route-Filter.CourseId="@Model.Filter?.CourseId"
                       asp-route-Filter.MinPassMark="@Model.Filter?.MinPassMark"
                       asp-route-Filter.MaxPassMark="@Model.Filter?.MaxPassMark">

                        Next

                    </a>

                </li>
            }

        </ul>

    </nav>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {

        document.querySelectorAll(".btn-delete").forEach(button => {

            button.addEventListener("click", function () {

                const form = this.closest("form");

                Swal.fire({

                    title: "Are you sure?",

                    text: "This action cannot be undone!",

                    icon: "warning",

                    showCancelButton: true,

                    confirmButtonColor: "#d33",

                    cancelButtonColor: "#3085d6",

                    confirmButtonText: "Yes, delete it!"

                }).then((result) => {

                    if(result.isConfirmed){

                        form.submit();

                    }

                });

            });

        });

    });

</script>

@section Scripts {

    <partial name="_NotificationPartial" />

}
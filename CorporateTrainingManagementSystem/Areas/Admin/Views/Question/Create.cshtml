@model CreateQuestionVM

<div class="container">

    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Create New Question</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">

            <form method="post">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <!-- Course -->

                <div class="mb-3">

                    <label asp-for="CourseId"
                           class="form-label"></label>

                    <select asp-for="CourseId"
                            asp-items="Model.Courses"
                            class="form-select"
                            id="CourseId">

                        <option value="">
                            Select Course
                        </option>

                    </select>

                    <span asp-validation-for="CourseId"
                          class="text-danger">
                    </span>

                </div>

                <!-- Exam -->

                <div class="mb-3">

                    <label asp-for="ExamId"
                           class="form-label"></label>

                    <select asp-for="ExamId"
                            asp-items="Model.Exams"
                            class="form-select"
                            id="ExamId">

                        <option value="">
                            Select Exam
                        </option>

                    </select>

                    <span asp-validation-for="ExamId"
                          class="text-danger">
                    </span>

                </div>

                <!-- Question -->

                <div class="mb-3">

                    <label asp-for="QuestionText"
                           class="form-label"></label>

                    <textarea asp-for="QuestionText"
                              class="form-control"
                              rows="3">
                    </textarea>

                    <span asp-validation-for="QuestionText"
                          class="text-danger">
                    </span>

                </div>

                <!-- Question Type -->

                <div class="mb-3">

                    <label asp-for="QuestionType"
                           class="form-label"></label>

                    <select asp-for="QuestionType"
                            asp-items="Html.GetEnumSelectList<QuestionType>()"
                            class="form-select"
                            id="QuestionType">
                    </select>

                    <span asp-validation-for="QuestionType"
                          class="text-danger">
                    </span>

                </div>

                <!-- Choices -->

                <div id="mcq-section">

                    <h5 class="mb-3">
                        Choices
                    </h5>

                    @for (int i = 0; i < Model.Choices.Count; i++)
                    {
                        <div class="row mb-3">

                            <div class="col-md-10">

                                <input asp-for="Choices[i].ChoiceText"
                                       class="form-control"
                                       placeholder="Choice @(i + 1)" />

                                <span asp-validation-for="Choices[i].ChoiceText"
                                      class="text-danger">
                                </span>

                            </div>

                            <div class="col-md-2 d-flex align-items-center">

                                <input class="form-check-input me-2"
                                       type="radio"
                                       asp-for="CorrectChoice"
                                       value="@(i + 1)" />

                                <label class="form-check-label">

                                    Correct

                                </label>

                            </div>

                        </div>
                    }

                </div>

                <!-- True / False -->

                <div id="truefalse-section"
                     style="display:none;">

                    <h5 class="mb-3">

                        Correct Answer

                    </h5>

                    <div class="form-check mb-2">

                        <input class="form-check-input"
                               type="radio"
                               asp-for="CorrectChoice"
                               value="1" />

                        <label class="form-check-label">

                            True

                        </label>

                    </div>

                    <div class="form-check">

                        <input class="form-check-input"
                               type="radio"
                               asp-for="CorrectChoice"
                               value="2" />

                        <label class="form-check-label">

                            False

                        </label>

                    </div>

                </div>

                <div class="mt-4">

                    <button type="submit"
                            class="btn btn-primary">

                        Create

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Cancel

                    </a>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/question.js"></script>
}
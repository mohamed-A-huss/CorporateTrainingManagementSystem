@model QuestionVM

<div class="container">

    <div class="row my-4">
        <div class="col-md-8">

            <h2 class="display-6">Question Details</h2>

            <hr />

            <dl class="row">

                <dt class="col-sm-3">
                    Course
                </dt>

                <dd class="col-sm-9">
                    @Model.CourseTitle
                </dd>

                <dt class="col-sm-3">
                    Exam
                </dt>

                <dd class="col-sm-9">
                    @Model.ExamTitle
                </dd>

                <dt class="col-sm-3">
                    Question
                </dt>

                <dd class="col-sm-9">
                    @Model.QuestionText
                </dd>

                <dt class="col-sm-3">
                    Type
                </dt>

                <dd class="col-sm-9">
                    @Model.QuestionType
                </dd>

            </dl>

            <hr />

            <h5>Choices</h5>

            <ul class="list-group mb-4">

                @foreach (var choice in Model.Choices)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">

                        <span>
                            @choice.ChoiceText
                        </span>

                        @if (choice.IsCorrect)
                        {
                            <span class="badge bg-success">
                                Correct
                            </span>
                        }

                    </li>
                }

            </ul>

            <a asp-action="Edit"
               asp-route-id="@Model.QuestionId"
               class="btn btn-warning">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                Back
            </a>

        </div>
    </div>

</div>
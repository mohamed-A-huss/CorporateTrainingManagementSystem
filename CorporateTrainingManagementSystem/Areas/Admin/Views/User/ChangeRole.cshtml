@model ChangeRoleVM

<div class="container">

    <div class="row mb-3 align-items-center my-3">

        <div class="col-md-6">

            <h2 class="display-6">

                Change User Role

            </h2>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <form asp-action="ChangeRole"
                  method="post">

                <input asp-for="UserId" type="hidden" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-3">

                    <label class="form-label fw-bold">

                        User

                    </label>

                    <input class="form-control"
                           value="@Model.FullName"
                           readonly />

                </div>

                <div class="mb-4">

                    <label asp-for="SelectedRole"
                           class="form-label">
                    </label>

                    <select asp-for="SelectedRole"
                            asp-items="Model.Roles"
                            class="form-select">

                        <option value="">
                            Select Role
                        </option>

                    </select>

                    <span asp-validation-for="SelectedRole"
                          class="text-danger">
                    </span>

                </div>

                <button type="submit"
                        class="btn btn-primary">

                    <i class="bi bi-check-circle"></i>

                    Save

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}
@model PaginatedUsers
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory Factory
@{
    var Localizer = Factory.Create(
        "SharedResource",
        "CorporateTrainingManagementSystem");
}
<div class="container">

    <div class="row my-3 align-items-center">

        <div class="col-md-6">

            <h2 class="display-6">
                @Localizer["User Management"]
            </h2>

        </div>
        <div class="col-md-6 text-end">

            <a asp-action="Create"
               class="btn btn-success">

                <i class="bi bi-plus-circle"></i>

                @Localizer["Create"]

            </a>

        </div>

    </div>

    <form asp-action="Index"
          method="get"
          class="card card-body shadow-sm mb-4">

        <div class="row g-3">

            <div class="col-md-4">

                <label asp-for="Filter.Search"
                       class="form-label">
                </label>

                <input asp-for="Filter.Search"
                       class="form-control"
                       placeholder="Search by Name or Email" />

            </div>
            <div>
                <div class="col-md-3">

                    <label asp-for="Filter.DepartmentId"
                           class="form-label">
                        @Localizer["Department"]
                    </label>

                    <select asp-for="Filter.DepartmentId"
                            asp-items="Model.Filter.Departments"
                            class="form-select">

                        <option value="">@Localizer["All Departments"]</option>

                    </select>

                </div>

            </div>
            <div>
                <div class="col-md-3">

                    <label asp-for="Filter.Role"
                           class="form-label">
                        @Localizer["Role"]
                    </label>

                    <select asp-for="Filter.Role"
                            asp-items="Model.Filter.Roles"
                            class="form-select">

                        <option value="">@Localizer["All Roles"]</option>

                    </select>

                </div>

            </div>

            <div class="col-md-2 d-flex align-items-end">

                <button class="btn btn-primary w-100">

                    <i class="bi bi-search"></i>

                    @Localizer["Search"]

                </button>

            </div>

        </div>

    </form>

    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                    <tr>

                        <th>@Localizer["Name"]</th>

                        <th>@Localizer["Email"]</th>

                        <th>@Localizer["Department"]</th>

                        <th>@Localizer["Role"]</th>

                        <th>@Localizer["Points"]</th>

                        <th>@Localizer["Status"]</th>

                        <th width="80"></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var user in Model.Users)
                    {
                        <tr>

                            <td>@user.FullName</td>

                            <td>@user.Email</td>

                            <td>@user.Department</td>

                            <td>@user.Role</td>

                            <td>@user.Points</td>

                            <td>

                                @if (user.IsLocked)
                                {
                                    <span class="badge bg-danger">

                                        @Localizer["Locked"]

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">

                                        @Localizer["Active"]

                                    </span>
                                }

                            </td>

                            <td>

                                <div class="dropdown">

                                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                                            type="button"
                                            data-toggle="dropdown"
                                            aria-haspopup="true"
                                            aria-expanded="false">

                                        @Localizer["Actions"]

                                    </button>

                                    <ul class="dropdown-menu dropdown-menu-end">

                                        <li>

                                            <a class="dropdown-item"
                                               asp-action="Details"
                                               asp-route-id="@user.Id">

                                                <i class="bi bi-eye"></i>

                                                @Localizer["Details"]

                                            </a>

                                        </li>

                                        <li>
                                            @if (user.Role != SD.ADMIN_ROLE && user.Role != SD.SUPER_ADMIN_ROLE)
                                            {
                                                <a class="dropdown-item"
                                                asp-action="ChangeRole"
                                                asp-route-id="@user.Id">

                                                    <i class="bi bi-arrow-repeat"></i>

                                                    @Localizer["Change Role"]

                                                </a>
                                            }
                                        </li>

                                        <li><hr class="dropdown-divider" /></li>

                                        <li>
                                            @if (user.Role != SD.ADMIN_ROLE &&user.Role != SD.SUPER_ADMIN_ROLE)
                                            {
                                            <form asp-action="ToggleLock"
                                                  method="post">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@user.Id" />

                                                <button class="dropdown-item">

                                                    @if (user.IsLocked)
                                                    {
                                                        <text>

                                                            <i class="bi bi-unlock"></i>

                                                            @Localizer["Unlock"]

                                                        </text>
                                                    }
                                                    else
                                                    {
                                                        <text>

                                                            <i class="bi bi-lock"></i>

                                                            @Localizer["Lock"]

                                                        </text>
                                                    }

                                                </button>

                                            </form>
                                            }
                                        </li>

                                    </ul>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-4">

        <ul class="pagination justify-content-center">

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">

                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-Search="@Model.Filter.Search"
                       asp-route-DepartmentId="@Model.Filter.DepartmentId"
                       asp-route-Role="@Model.Filter.Role">

                        @i

                    </a>

                </li>
            }

        </ul>

    </nav>
}
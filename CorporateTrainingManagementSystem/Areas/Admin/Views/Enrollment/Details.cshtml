@model EnrollmentVM

<div class="container">

    <div class="row my-4">

        <div class="col-md-6">

            <h2 class="display-6">

                Enrollment Details

            </h2>

        </div>

    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-6">

                    <label class="form-label fw-bold">

                        Trainee

                    </label>

                    <input class="form-control"
                           value="@Model.TraineeName"
                           readonly />

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-bold">

                        Course

                    </label>

                    <input class="form-control"
                           value="@Model.CourseTitle"
                           readonly />

                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="form-label fw-bold">

                        Enrollment Date

                    </label>

                    <input class="form-control"
                           value="@Model.EnrollmentDate.ToString("dd MMM yyyy")"
                           readonly />

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-bold">

                        Current Status

                    </label>

                    <div class="mt-2">

                        @switch (Model.Status)
                        {
                            case EnrollmentStatus.Active:

                                <span class="badge bg-success fs-6">

                                    Active

                                </span>

                                break;

                            case EnrollmentStatus.Completed:

                                <span class="badge bg-primary fs-6">

                                    Completed

                                </span>

                                break;

                            case EnrollmentStatus.Cancelled:

                                <span class="badge bg-danger fs-6">

                                    Cancelled

                                </span>

                                break;
                        }

                    </div>

                </div>

            </div>

            @if (Model.Status == EnrollmentStatus.Active)
            {
                <hr />

                <h5 class="mb-3">

                    Change Status

                </h5>

                <div class="d-flex gap-2">

                    <form asp-action="ChangeStatus"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@Model.EnrollmentId" />

                        <input type="hidden"
                               name="status"
                               value="@EnrollmentStatus.Completed" />

                        <button class="btn btn-success">

                            <i class="bi bi-check-circle"></i>

                            Mark as Completed

                        </button>

                    </form>

                    <form asp-action="ChangeStatus"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden"
                               name="id"
                               value="@Model.EnrollmentId" />

                        <input type="hidden"
                               name="status"
                               value="@EnrollmentStatus.Cancelled" />

                        <button class="btn btn-danger">

                            <i class="bi bi-x-circle"></i>

                            Cancel Enrollment

                        </button>

                    </form>

                </div>
            }
            else
            {
                <hr />

                <div class="alert alert-info">

                    This enrollment is finalized and its status can no longer be changed.

                </div>
            }

            <hr />

            <a asp-action="Index"
               class="btn btn-secondary">

                Back

            </a>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_NotificationPartial" />
}
@model EditDepartmentVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Edit Department</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post">

                <input asp-for="DepartmentId" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger" placeholder="Name"></span>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <button type="submit" class="btn btn-primary">Submit</button>

                <a asp-area="Admin"
                   asp-controller="Department"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial">
}
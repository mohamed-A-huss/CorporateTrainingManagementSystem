@model CourseVM

<div class="container">

    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Course Details</h2>
        </div>
    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-6">

                    <label class="form-label fw-bold">Title</label>

                    <input class="form-control"
                           value="@Model.Title"
                           readonly />

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-bold">Instructor</label>

                    <input class="form-control"
                           value="@Model.InstructorName"
                           readonly />

                </div>

            </div>

            <div class="row mb-3">

                <div class="col-md-6">

                    <label class="form-label fw-bold">Created At</label>

                    <input class="form-control"
                           value="@Model.CreatedAt.ToString("dd MMM yyyy")"
                           readonly />

                </div>

            </div>

            <div class="mb-3">

                <label class="form-label fw-bold">Description</label>

                <textarea class="form-control"
                          rows="5"
                          readonly>@Model.Description</textarea>

            </div>

            <a asp-action="Edit"
               asp-route-id="@Model.CourseId"
               class="btn btn-warning">

                <i class="bi bi-pencil-square"></i>

                Edit

            </a>

            <a asp-action="Index"
               class="btn btn-secondary">

                Back

            </a>

        </div>

    </div>

</div>
@model VerifyCertificateVM

@{
    ViewData["Title"] = "Certificate Verification";
    Layout = "_AuthLayout";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-body text-center">

                    @if (Model.IsValid)
                    {
                        <i class="fas fa-check-circle text-success fa-5x mb-4"></i>

                        <h2 class="text-success">
                            Certificate Verified
                        </h2>

                        <hr />

                        <h4>@Model.StudentName</h4>

                        <p class="text-muted">

                            Successfully completed

                        </p>

                        <h5 class="text-primary">

                            @Model.CourseTitle

                        </h5>

                        <br />

                        <p>

                            <strong>Issue Date:</strong>

                            @Model.IssueDate.ToString("dd MMM yyyy")

                        </p>

                        <p>

                            <strong>Certificate Number:</strong>

                            @Model.CertificateNumber

                        </p>
                    }
                    else
                    {
                        <i class="fas fa-times-circle text-danger fa-5x mb-4"></i>

                        <h2 class="text-danger">

                            Invalid Certificate

                        </h2>

                        <p>

                            The certificate number you entered does not exist.

                        </p>
                    }

                </div>

            </div>

        </div>

    </div>

</div>
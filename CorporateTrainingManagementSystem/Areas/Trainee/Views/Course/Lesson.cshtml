@model TraineeLessonDetailsVM

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid mt-3">

    <a asp-action="Details"
       asp-route-id="@Model.CourseId"
       class="btn btn-outline-secondary mb-3">

        <i class="fas fa-arrow-left"></i>

        Back to Course

    </a>

    <div class="card shadow-sm">

        <div class="card-header">

            <h3 class="mb-0">

                @Model.Title

            </h3>

        </div>

        <div class="card-body">

            @if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
            {
                <div class="card mb-3">

                    <div class="card-header">
                        <h5 class="mb-0">Video Lesson</h5>
                    </div>

                    <div class="card-body">

                        <p class="text-muted">
                            Click the button below to open the lesson video in a new tab.
                        </p>

                        <a href="@Model.VideoUrl"
                           target="_blank"
                           class="btn btn-primary">

                            <i class="fas fa-external-link-alt me-2"></i>
                            Watch Video

                        </a>

                    </div>

                </div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Content))
            {
                <div class="mb-4">

                    <h5>Lesson Content</h5>

                    <div class="border rounded p-3 bg-light">

                        @Html.Raw(Model.Content)

                    </div>

                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.PdfPath))
            {
                <div class="mb-4">

                    <h5>Lesson Material</h5>

                    <a href="@Model.PdfPath"
                       target="_blank"
                       class="btn btn-outline-danger">

                        <i class="fas fa-file-pdf"></i>

                        Open PDF

                    </a>

                </div>
            }

            <hr />

            @if (!Model.IsCompleted)
            {
                <form asp-action="MarkAsRead"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="lessonId"
                           value="@Model.LessonId" />

                    <button class="btn btn-success">

                        <i class="fas fa-check-circle"></i>

                        Mark As Read

                    </button>

                </form>
            }
            else
            {
                <button class="btn btn-success"
                        disabled>

                    <i class="fas fa-check-circle"></i>

                    Completed

                </button>
            }

        </div>

        <div class="card-footer d-flex justify-content-between">

            @if (Model.HasPreviousLesson)
            {
                <a asp-action="Lesson"
                   asp-route-id="@Model.PreviousLessonId"
                   class="btn btn-outline-primary">

                    <i class="fas fa-arrow-left"></i>

                    Previous Lesson

                </a>
            }
            else
            {
                <span></span>
            }

            @if (Model.HasNextLesson)
            {
                <a asp-action="Lesson"
                   asp-route-id="@Model.NextLessonId"
                   class="btn btn-primary">

                    Next Lesson

                    <i class="fas fa-arrow-right"></i>

                </a>
            }

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
@model TraineeCourseDetailsVM

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid">

    <div class="row mt-3">

        <div class="col-md-8">

            <div class="card">

                <div class="card-body">

                    <a asp-action="MyCourses"
                       class="btn btn-outline-secondary mb-3">

                        <i class="fas fa-arrow-left"></i>
                        Back

                    </a>

                    <h2>@Model.Title</h2>

                    <p class="text-muted">
                        @Model.Description
                    </p>

                    <hr />

                    <div class="progress mb-3" style="height:25px">

                        <div class="progress-bar bg-success"
                             role="progressbar"
                             style="width:@Model.ProgressPercentage%">

                            @Model.ProgressPercentage%

                        </div>

                    </div>

                    <p>

                        <strong>
                            @Model.CompletedLessons
                        </strong>

                        /

                        <strong>
                            @Model.TotalLessons
                        </strong>

                        Lessons Completed

                    </p>

                </div>

            </div>

            <div class="card mt-3">

                <div class="card-header">

                    <h5 class="mb-0">

                        Lessons

                    </h5>

                </div>

                <div class="list-group list-group-flush">

                    @foreach (var lesson in Model.Lessons)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">

                            <div>

                                <h6 class="mb-1">

                                    @lesson.Title

                                </h6>

                                @if (lesson.IsCompleted)
                                {
                                    <span class="badge badge-success">

                                        Completed

                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-warning">

                                        Not Completed

                                    </span>
                                }

                            </div>

                            <a asp-action="Lesson"
                               asp-route-id="@lesson.LessonId"
                               class="btn btn-primary btn-sm">

                                Open

                            </a>

                        </div>
                    }

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card">

                <div class="card-header">

                    <h5 class="mb-0">

                        Final Exam

                    </h5>

                </div>

                <div class="card-body">

                    <p>

                        <strong>Attempts:</strong>

                        @Model.AttemptsUsed / @Model.MaxAttempts

                    </p>

                    @if (!Model.CanTakeExam)
                    {
                        <div class="alert alert-warning">

                            Complete all lessons first.

                        </div>
                    }
                    else if (!Model.HasRemainingAttempts)
                    {
                        <div class="alert alert-danger">

                            You have used all attempts.

                        </div>
                    }
                    else
                    {
                        <a asp-controller="Exam"
                           asp-action="Start"
                           asp-route-id="@Model.ExamId"
                           class="btn btn-success btn-block">

                            <i class="fas fa-play"></i>

                            Start Exam

                        </a>
                    }

                </div>

            </div>

        </div>

    </div>

</div>
@model IEnumerable<TraineeBadgeVM>

@{
    ViewData["Title"] = "My Badges";
}

<section class="content-header">

    <div class="container-fluid">

        <div class="row mb-2">

            <div class="col-sm-6">

                <h1>My Badges</h1>

            </div>

            <div class="col-sm-6">

                <ol class="breadcrumb float-sm-right">

                    <li class="breadcrumb-item">

                        <a asp-area="@SD.TRAINEE_AREA"
                           asp-controller="Home"
                           asp-action="Index">

                            Dashboard

                        </a>

                    </li>

                    <li class="breadcrumb-item active">

                        My Badges

                    </li>

                </ol>

            </div>

        </div>

    </div>

</section>

<section class="content">

    <div class="container-fluid">

        @if (!Model.Any())
        {
            <div class="card">

                <div class="card-body text-center py-5">

                    <i class="fas fa-award text-secondary"
                       style="font-size:70px;"></i>

                    <h3 class="mt-3">

                        No Badges Yet

                    </h3>

                    <p class="text-muted">

                        Complete courses and pass exams to unlock badges.

                    </p>

                    <a asp-area="@SD.TRAINEE_AREA"
                       asp-controller="Course"
                       asp-action="Browse"
                       class="btn btn-primary">

                        Browse Courses

                    </a>

                </div>

            </div>
        }
        else
        {
            <div class="row">

                @foreach (var badge in Model)
                {
                    <div class="col-lg-4 col-md-6">

                        <div class="card card-warning card-outline shadow-sm h-100">

                            <div class="card-body text-center">

                                <div class="mb-3">

                                    <i class="fas @badge.Icon @badge.Color"
                                       style="font-size:60px;"></i>

                                </div>

                                <h4>

                                    @badge.Name

                                </h4>

                                <p class="text-muted">

                                    @badge.Description

                                </p>

                                <hr />

                                <small class="text-secondary">

                                    Earned on

                                </small>

                                <br />

                                <strong>

                                    @badge.AwardedDate.ToString("dd MMM yyyy")

                                </strong>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</section>
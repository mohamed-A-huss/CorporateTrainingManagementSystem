@model TraineeTakeExamVM

@{
    ViewData["Title"] = Model.ExamTitle;
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header d-flex justify-content-between align-items-center">

            <h3 class="mb-0">
                @Model.ExamTitle
            </h3>

            <span class="badge bg-danger fs-6" id="timer">
                Loading...
            </span>

        </div>

        <div class="card-body">

            <form asp-action="Finish"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="AttemptId"
                       value="@Model.AttemptId" />

                @for (int i = 0; i < Model.Questions.Count; i++)
                {
                    <div class="card mb-4">

                        <div class="card-header">

                            <strong>

                                Question @(i + 1)

                            </strong>

                        </div>

                        <div class="card-body">

                            <input type="hidden"
                                   name="Answers[@i].QuestionId"
                                   value="@Model.Questions[i].QuestionId" />

                            <h5>

                                @Model.Questions[i].QuestionText

                            </h5>

                            <hr />

                            @foreach (var choice in Model.Questions[i].Choices)
                            {
                                <div class="form-check mb-2">

                                    <input class="form-check-input"
                                           type="radio"
                                           name="Answers[@i].SelectedChoiceId"
                                           value="@choice.ChoiceId"
                                           id="choice_@choice.ChoiceId" />

                                    <label class="form-check-label"
                                           for="choice_@choice.ChoiceId">

                                        @choice.ChoiceText

                                    </label>

                                </div>
                            }

                        </div>

                    </div>
                }

                <div class="text-end">

                    <button class="btn btn-success btn-lg"
                            type="submit">

                        Finish Exam

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts
{
    <script>

        const endTime = new Date("@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")");

        function updateTimer(){

            const now = new Date();

            const diff = endTime - now;

            if(diff <= 0){

                document.getElementById("timer").innerHTML = "00:00";

                return;
            }

            const minutes = Math.floor(diff / 60000);

            const seconds = Math.floor((diff % 60000) / 1000);

            document.getElementById("timer").innerHTML =
                String(minutes).padStart(2,'0')
                + ":"
                + String(seconds).padStart(2,'0');

        }

        updateTimer();

        setInterval(updateTimer,1000);

    </script>
}